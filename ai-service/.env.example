# Copy this file to .env and fill in real values. Never commit the real .env file.

OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

APP_ENV=development
ALLOWED_ORIGINS=http://localhost:5000,http://localhost:5001,http://localhost:3000

# Must match HRSystem.API's appsettings.json -> AIService:InternalApiKey
INTERNAL_API_KEY=CHANGE_THIS_SHARED_SECRET
